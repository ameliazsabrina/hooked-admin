{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@hooked/server/trpc": ["../hooked-clean/packages/server/src/trpc/router.ts"],
      "@hooked/server/trpc/*": ["../hooked-clean/packages/server/src/trpc/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "../hooked-clean/packages/server/src/trpc/router.ts",
    "../hooked-clean/packages/server/src/trpc/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
